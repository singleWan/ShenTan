# ============================================
# 神探 - 环境变量配置
# 使用方法：复制本文件为 .env，然后填写实际值
# cp .env.example .env
#
# 所有配置通过环境变量统一管理，无需额外配置文件
# ============================================

# ---------- 核心设置 ----------

# 默认使用的 Provider（对应下方定义的 Provider 名称）
PROVIDER_DEFAULT=anthropic

# 全局 AI 最大输出 Token
# 默认值：8000
# MAX_TOKENS=8000

# 数据库文件路径
# 默认值：./data/shentan.db
# DATABASE_PATH=./data/shentan.db

# Web 服务端口
# 默认值：3000
# PORT=3000

# ---------- Provider 定义 ----------
# 通过 PROVIDER_<名称>_* 环境变量定义 AI Provider
# 必须字段：TYPE（anthropic/openai/openai-compatible）、MODEL
# API Key 支持两种命名：PROVIDER_<名称>_API_KEY 或 <名称>_API_KEY

# Provider: anthropic (Anthropic Claude)
PROVIDER_ANTHROPIC_TYPE=anthropic
PROVIDER_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=sk-your-api-key

# Provider: openai (OpenAI 官方)
# PROVIDER_OPENAI_TYPE=openai
# PROVIDER_OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY=sk-your-api-key

# Provider: OpenAI 兼容接口（DeepSeek / Ollama 等）
# PROVIDER_CUSTOM_TYPE=openai-compatible
# PROVIDER_CUSTOM_MODEL=your-model
# PROVIDER_CUSTOM_BASE_URL=https://your-api-endpoint/v1
# PROVIDER_CUSTOM_API_KEY=sk-your-api-key

# ---------- SearXNG 搜索引擎 ----------

# SearXNG 基础 URL
# SEARXNG_BASE_URL=http://localhost:8080
# 是否启用（默认 true）
# SEARXNG_ENABLED=true
# 缓存 TTL（秒，默认 1800）
# SEARXNG_CACHE_TTL=1800

# ---------- API 重试与节流 ----------
# 遇到限速(429)或服务端错误(5xx)时自动重试，指数退避

# 最大重试次数（默认 3，设为 0 禁用重试）
# RETRY_MAX_RETRIES=3
# 首次重试延迟毫秒（默认 2000）
# RETRY_BASE_DELAY=2000
# 最大延迟毫秒（默认 30000）
# RETRY_MAX_DELAY=30000
# 两次 API 请求最小间隔毫秒（默认 1000，设为 0 禁用节流）
# API_MIN_INTERVAL=1000

# ---------- Agent 覆盖（可选） ----------
# 格式：AGENT_<名称>_MAX_ITERATIONS / AGENT_<名称>_MAX_TOKENS
# Agent 名称：BIOGRAPHER / EVENT_EXPLORER / STATEMENT_COLLECTOR / REACTION_COLLECTOR

# AGENT_BIOGRAPHER_MAX_ITERATIONS=25
# AGENT_EVENT_EXPLORER_MAX_ITERATIONS=25
# AGENT_STATEMENT_COLLECTOR_MAX_ITERATIONS=25
# AGENT_REACTION_COLLECTOR_MAX_ITERATIONS=30

# ---------- 质量控制（可选） ----------
# QUALITY_MAX_EXPLORE_ROUNDS=5
# QUALITY_MIN_EXPLORE_ROUNDS=2
# QUALITY_CONVERGENCE_THRESHOLD=2
# QUALITY_CONSECUTIVE_DRY_ROUNDS=2
