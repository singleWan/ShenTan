{
  "name": "shentan",
  "version": "0.1.0",
  "private": true,
  "description": "AI-driven character biography and event collection system",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @shentan/cli run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @shentan/core run db:generate",
    "db:migrate": "pnpm --filter @shentan/core run db:migrate",
    "cli": "pnpm --filter @shentan/cli run start",
    "web": "pnpm --filter @shentan/web run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  }
}
